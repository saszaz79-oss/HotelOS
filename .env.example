# HotelOS environment configuration
# Copy to .env and fill in real values for LOCAL DEVELOPMENT. Never commit .env.
#
# This file covers local dev only. For Cloudflare Workers production
# deployment, most of these become `wrangler secret put` values or
# wrangler.jsonc bindings instead of a .env file — see
# docs/CLOUDFLARE_DEPLOYMENT.md, docs/SUPABASE_SETUP.md, and docs/R2_SETUP.md
# for exactly which is which.

# --- Database ---
# Local dev / CI / migrations only (read by prisma.config.ts and
# src/lib/prisma.ts as a fallback). In production on Cloudflare Workers,
# runtime queries go through the Hyperdrive binding instead (no DATABASE_URL
# needed at runtime there) — but migrations still need this pointed at
# Supabase's DIRECT (non-pooled) connection string. See docs/SUPABASE_SETUP.md.
DATABASE_URL="postgresql://hotelos:hotelos@localhost:5432/hotelos?schema=public"

# --- Session security ---
# Currently unused (session tokens are random bearer tokens, not signed
# cookies — see src/server/modules/auth/session.ts). Reserved for future use.
SESSION_SECRET=""

# --- Storage adapter (Architecture §6) ---
# "local": filesystem — dev-only, never valid on Cloudflare Workers (no
#   writable filesystem there at all).
# "r2": Cloudflare R2 via the native binding — see docs/R2_SETUP.md.
#   STORAGE_R2_BINDING must match the binding name in wrangler.jsonc's
#   [[r2_buckets]] entry; no access-key/secret needed, R2 bindings are
#   authenticated by the Worker's own identity, not credentials.
STORAGE_DRIVER="local"                  # "local" | "r2"
STORAGE_LOCAL_PATH="./.storage"         # used only when STORAGE_DRIVER=local
STORAGE_R2_BINDING="HOTELOS_BUCKET"     # used only when STORAGE_DRIVER=r2

# --- AI provider abstraction (Architecture §8, §30) ---
# Required for the Executive AI Summary on Mission Control (Roadmap M4) to
# produce real output — without it, Mission Control shows a clear
# "AI summary not available" state rather than fabricating one.
AI_PROVIDER="anthropic"          # "anthropic" | "openai" (openai not yet implemented)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# --- Notification provider (Architecture §5, D9: mocked in v0.1) ---
NOTIFICATION_DRIVER="mock"       # "mock" logs to console/server logs only

# --- App ---
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="HotelOS"
