// HotelOS database schema — implements docs/DATABASE_SCHEMA.md plus the
// Timeline/Memory additions from docs/ARCHITECTURE.md §14-15 (see
// docs/DECISIONS.md "Post-Pivot Consistency Review" for why this file is
// ahead of the Phase-0 DATABASE_SCHEMA.md doc, which predates the pivot).

// Prisma 7: no `url` here — connection URLs live in prisma.config.ts (for
// the CLI/migrations) and are supplied to PrismaClient via a driver adapter
// at runtime (see src/lib/prisma.ts). This is also what makes the client
// Cloudflare Workers-compatible: Prisma 7 has no Rust query-engine binary
// path anymore, only the driver-adapter path (Architecture, Cloudflare
// deployment docs).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------- Identity & Access ----------

enum Language {
  ar
  en
}

enum UserStatus {
  active
  disabled
}

model User {
  id                 String     @id @default(cuid())
  username           String     @unique
  passwordHash       String
  displayName        String
  preferredLanguage  Language   @default(ar)
  isSuperAdmin       Boolean    @default(false)
  status             UserStatus @default(active)
  // Set whenever a temporary password is issued (initial Hotel Admin
  // creation, admin-triggered reset) — enforced at the (app) layout level,
  // blocking access to the rest of the product until the user sets their
  // own password. Never true for a user who chose their own password.
  mustChangePassword Boolean    @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  memberships             HotelMembership[]
  sessions                Session[]
  passwordResets          PasswordResetToken[]
  uploads                 ReportUpload[]
  correctedMetrics        HotelMetric[]           @relation("MetricCorrectedBy")
  aiConversations         AIConversation[]
  exportedReports         ExportedReport[]
  auditLogs               AuditLog[]
  timelineEvents          TimelineEvent[]
  groundTruthRecords      ExtractionGroundTruth[]
  notifications           Notification[]
  generatedAiSummaries    AiExecutiveSummary[]    @relation("AiSummaryGeneratedBy")
  createdAnalysisSessions AnalysisSession[]
}

model Session {
  // Not a @default(cuid()) — the id itself is the bearer session token
  // (crypto.randomBytes(32), generated in src/server/modules/auth/session.ts),
  // so a leaked cuid-shaped id elsewhere in the app never doubles as a valid
  // session credential.
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

enum HotelStatus {
  active
  suspended
  archived
}

model Hotel {
  id                String      @id @default(cuid())
  name              String
  logoUrl           String?
  country           String
  city              String
  timezone          String
  currency          String      @default("SAR")
  totalRooms        Int
  roomTypes         Json        @default("[]")
  pmsType           String?
  licenseStartDate  DateTime?
  licenseExpiryDate DateTime?
  status            HotelStatus @default(active)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Executive Intelligence Report branding (EDI Phase 1) — all nullable,
  // never backfilled. A report with a missing field shows an honest
  // configurable placeholder (Constitution truth test), never a fabricated
  // name/title. `name` above stays the operational/display name used
  // everywhere else in the app; these are specifically the cover-page
  // identity fields, distinct because a hotel's official bilingual legal
  // name can differ from what's shown in nav/lists.
  officialNameAr      String?
  officialNameEn      String?
  propertyCode        String?
  generalManagerName  String?
  generalManagerTitle String?
  contactPhone        String?
  contactEmail        String?
  address             String?
  reportFooterText    String?

  memberships          HotelMembership[]
  reportUploads        ReportUpload[]
  metrics              HotelMetric[]
  insights             Insight[]
  alerts               Alert[]
  recommendations      Recommendation[]
  aiConversations      AIConversation[]
  exportedReports      ExportedReport[]
  auditLogs            AuditLog[]
  settings             HotelSetting[]
  subscription         Subscription?
  timelineEvents       TimelineEvent[]
  notifications        Notification[]
  aiExecutiveSummaries AiExecutiveSummary[]
  analysisSessions     AnalysisSession[]

  @@index([status])
}

enum HotelRole {
  HOTEL_ADMIN
  GENERAL_MANAGER
  FRONT_OFFICE_MANAGER
  REVENUE_MANAGER
  ANALYST
  READ_ONLY
}

enum MembershipStatus {
  active
  revoked
}

model HotelMembership {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotelId   String
  hotel     Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  role      HotelRole
  status    MembershipStatus @default(active)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, hotelId])
  @@index([hotelId, userId])
}

// ---------- Reports & Extraction ----------

enum ReportUploadStatus {
  uploaded
  processing
  needs_review
  complete
  error
}

model ReportUpload {
  id               String             @id @default(cuid())
  hotelId          String
  hotel            Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  uploadedByUserId String
  uploadedBy       User               @relation(fields: [uploadedByUserId], references: [id])
  originalFilename String
  storageKey       String
  fileSizeBytes    Int
  checksumSha256   String
  mimeType         String
  status           ReportUploadStatus @default(uploaded)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Nullable (EDI Phase 1) — every upload that predates the Analysis
  // Session model simply has this unset, a valid permanent state, not an
  // error. Historical uploads keep showing in Archive exactly as before;
  // only session-tagged uploads show on the Upload page's session cards.
  analysisSessionId String?
  analysisSession   AnalysisSession? @relation(fields: [analysisSessionId], references: [id], onDelete: SetNull)

  documents ReportDocument[]

  @@index([hotelId, createdAt])
  @@index([hotelId, status])
  @@index([hotelId, uploadedByUserId])
  @@index([analysisSessionId])
}

enum ReportType {
  MANAGER_FLASH
  RESERVATION_STATISTICS
  OPEN_BALANCE
  RESERVATION_STATISTICS_1
  // Added EDI Phase 1 — required Analysis Session slots with no extraction
  // adapter yet (no known field layout to build against). Upload/type-match
  // only for now; see report-extraction/adapters/ for the honest "not yet
  // structurally validated" distinction from MANAGER_FLASH.
  HISTORY_FORECAST
  DAY_MTD_YTD_STATISTICS
  GENERIC
}

// One open Analysis Session per hotel at a time (EDI Phase 1) — the
// coordinating unit for "today's work": which uploads belong together, what
// pipeline stage the background Executive Analysis job is at, and a stable
// id to poll/navigate around. Deliberately thin — HotelMetric/Insight
// already converge naturally per (hotelId, metricDate), so this model does
// not duplicate metric storage, only workflow/progress state.
enum AnalysisSessionStatus {
  collecting
  analyzing
  ready
  error
}

enum AnalysisSessionStage {
  reading
  extracting
  normalizing
  consistency
  kpi
  score
  executive_intelligence
  report
  pdf
  complete
  error
}

model AnalysisSession {
  id              String                @id @default(cuid())
  hotelId         String
  hotel           Hotel                 @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  businessDate    DateTime
  status          AnalysisSessionStatus @default(collecting)
  currentStage    AnalysisSessionStage?
  createdByUserId String
  createdBy       User                  @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime              @default(now())
  completedAt     DateTime?
  errorMessage    String?

  uploads ReportUpload[]

  @@index([hotelId, status])
  @@index([hotelId, businessDate])
}

enum DataQualityValidationStatus {
  passed
  flagged
  failed
}

model ReportDocument {
  id                   String       @id @default(cuid())
  reportUploadId       String
  reportUpload         ReportUpload @relation(fields: [reportUploadId], references: [id], onDelete: Cascade)
  hotelId              String
  reportType           ReportType
  detectedReportDate   DateTime?
  confirmedReportDate  DateTime?
  extractionConfidence Float?
  rawExtractedText     String?
  checksumSha256       String
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  // Data Quality Engine (Architecture §33) — populated at the validate stage.
  completenessScore Float?
  validationStatus  DataQualityValidationStatus?
  qualityNotes      Json                         @default("[]")
  // Non-fatal parser-level warnings (Validation Phase §1/§3) — distinct from
  // per-field qualityNotes: these are about the extraction attempt itself
  // (e.g. "no title marker found"), not about a specific metric.
  parserWarnings    Json                         @default("[]")

  // Candidate values pending manual review (PRD §4) — normalization into
  // HotelMetric happens only after user confirmation (Roadmap M4).
  extractedFields Json @default("[]")

  extractionJobs ExtractionJob[]
  metrics        HotelMetric[]
  groundTruth    ExtractionGroundTruth?

  @@index([hotelId, reportType, confirmedReportDate])
}

// Real Data Mode (Validation Phase §9): an engineer-entered set of expected
// field values for one report, used only to measure parser accuracy — never
// read by the normal report workflow. One per ReportDocument. Populating
// this against a real Opera export and running `compareExtractionAccuracy`
// is how "current accuracy" in the Validation Report stops being "unmeasured."
model ExtractionGroundTruth {
  id               String         @id @default(cuid())
  reportDocumentId String         @unique
  reportDocument   ReportDocument @relation(fields: [reportDocumentId], references: [id], onDelete: Cascade)
  expectedFields   Json           @default("{}")
  notes            String?
  recordedByUserId String
  recordedBy       User           @relation(fields: [recordedByUserId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

enum ExtractionStage {
  upload
  extract
  validate
  normalize
  analyze
  complete
  error
}

model ExtractionJob {
  id               String          @id @default(cuid())
  reportDocumentId String
  reportDocument   ReportDocument  @relation(fields: [reportDocumentId], references: [id], onDelete: Cascade)
  stage            ExtractionStage @default(upload)
  attempt          Int             @default(1)
  startedAt        DateTime        @default(now())
  completedAt      DateTime?
  errorMessage     String?

  @@index([reportDocumentId])
}

// ---------- Metrics ----------

model MetricDefinition {
  key        String  @id
  labelEn    String
  labelAr    String
  unit       String
  isComputed Boolean @default(false)

  metrics HotelMetric[]
}

model HotelMetric {
  id                     String           @id @default(cuid())
  hotelId                String
  hotel                  Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  metricDate             DateTime
  metricKey              String
  metricDefinition       MetricDefinition @relation(fields: [metricKey], references: [key])
  value                  Float?
  sourceReportDocumentId String?
  sourceReportDocument   ReportDocument?  @relation(fields: [sourceReportDocumentId], references: [id])
  isManuallyCorrected    Boolean          @default(false)
  correctedByUserId      String?
  correctedBy            User?            @relation("MetricCorrectedBy", fields: [correctedByUserId], references: [id])
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@unique([hotelId, metricDate, metricKey])
  @@index([hotelId, metricDate])
}

// ---------- Insights ----------

model Insight {
  id                 String   @id @default(cuid())
  hotelId            String
  hotel              Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  insightDate        DateTime
  healthScore        Float?
  healthScoreFactors Json     @default("[]")
  generatedAt        DateTime @default(now())

  alerts          Alert[]
  recommendations Recommendation[]

  @@unique([hotelId, insightDate])
  @@index([hotelId, insightDate])
}

enum AlertSeverity {
  critical
  warning
  info
}

enum AlertStatus {
  open
  acknowledged
  resolved
}

model Alert {
  id               String        @id @default(cuid())
  hotelId          String
  hotel            Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  insightId        String?
  insight          Insight?      @relation(fields: [insightId], references: [id])
  severity         AlertSeverity
  category         String
  messageEn        String
  messageAr        String
  relatedMetricKey String?
  status           AlertStatus   @default(open)
  createdAt        DateTime      @default(now())

  @@index([hotelId, createdAt])
  @@index([insightId])
}

enum RecommendationCategory {
  risk
  opportunity
  action
}

model Recommendation {
  id                String                 @id @default(cuid())
  hotelId           String
  hotel             Hotel                  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  insightId         String
  insight           Insight                @relation(fields: [insightId], references: [id])
  priority          Int
  // "Why" (Decision Engine, Architecture §31/§27): the rationale, in the
  // requesting user's language, referencing the supporting metrics below.
  textEn            String
  textAr            String
  // Distinct from the rationale — a concrete, actionable next step.
  suggestedActionEn String
  suggestedActionAr String
  // v0.1 recommendations are deterministic/rule-based (see insights module),
  // so confidence reflects rule certainty, not a model's self-reported
  // confidence — kept as a float for a consistent shape once AI-generated
  // recommendations (Roadmap M6+) populate it differently.
  confidence        Float
  // Traceability (Constitution truth test): which HotelMetric rows this
  // recommendation was computed from, with enough detail to re-derive it.
  supportingMetrics Json                   @default("[]")
  category          RecommendationCategory
  // Outcome tracking seeds the Hotel Genome (Architecture §15 v0.1 scope) —
  // "open" until a user accepts/dismisses/supersedes it.
  status            String                 @default("open")
  createdAt         DateTime               @default(now())
  // Added Analytics fix Phase 6 — all three nullable and never backfilled:
  // rows created before this migration show "not available" honestly rather
  // than a fabricated guess (Constitution truth test). Populated
  // deterministically by insights/rules.ts at rule-evaluation time, same
  // vocabulary HotelRole already uses (owner is who should act on this).
  owner             HotelRole?
  timeframe         String?
  expectedOutcomeEn String?
  expectedOutcomeAr String?

  @@index([hotelId, createdAt])
  @@index([insightId])
}

// Persisted AI Executive Summary (Perf fix, Phase 1B) — before this model,
// generateExecutiveSummary() ran on every single page render of Mission
// Control and Executive Export with no caching, meaning every page view
// made a live AI API call. One row per (hotel, date, language); read
// through getOrRefreshExecutiveSummary() in ai-orchestration/commands.ts,
// which regenerates only on staleness (see isStale()), not on every read.
model AiExecutiveSummary {
  id                     String   @id @default(cuid())
  hotelId                String
  hotel                  Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  metricDate             DateTime
  language               Language
  summaryText            String
  // Snapshot of CitedMetric[] at generation time — avoids recomputing
  // citations on every read; the underlying HotelMetric rows remain the
  // real source of truth (Constitution truth test), this is a display cache.
  citedMetrics           Json     @default("[]")
  model                  String
  promptVersion          Int
  analysisVersion        Int
  sourceReportDocumentId String?
  generatedAt            DateTime @default(now())
  // Null for a system-generated (cache-miss) summary; set only when a user
  // explicitly clicked Regenerate.
  generatedByUserId      String?
  generatedBy            User?    @relation("AiSummaryGeneratedBy", fields: [generatedByUserId], references: [id])

  @@unique([hotelId, metricDate, language])
  @@index([hotelId, metricDate])
}

// ---------- Agents & AI ----------

model AIConversation {
  id        String   @id @default(cuid())
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  agentId   String   @default("executive-agent")
  title     String?
  createdAt DateTime @default(now())

  messages AIMessage[]

  @@index([hotelId, userId, createdAt])
}

enum AIMessageRole {
  user
  assistant
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           AIMessageRole
  content        String
  citedSources   Json           @default("[]")
  messageType    Json           @default("{}")
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
}

// ---------- Hotel Timeline (Architecture §14) ----------

enum TimelineEventType {
  report_uploaded
  report_extracted
  report_finalized
  metric_corrected
  alert_raised
  alert_resolved
  recommendation_issued
  ai_conversation
  ai_summary_generated
  export_generated
  decision_logged
}

model TimelineEvent {
  id          String            @id @default(cuid())
  hotelId     String
  hotel       Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  eventType   TimelineEventType
  actorUserId String?
  actor       User?             @relation(fields: [actorUserId], references: [id])
  payload     Json              @default("{}")
  sourceRef   String?
  createdAt   DateTime          @default(now())

  @@index([hotelId, createdAt])
}

// ---------- Exports & Archive ----------

enum ExportStatus {
  generated
  failed
}

model ExportedReport {
  id                String       @id @default(cuid())
  hotelId           String
  hotel             Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  generatedByUserId String
  generatedBy       User         @relation(fields: [generatedByUserId], references: [id])
  language          Language
  periodStart       DateTime
  periodEnd         DateTime
  storageKey        String?
  status            ExportStatus @default(generated)
  createdAt         DateTime     @default(now())

  @@index([hotelId, createdAt])
}

// ---------- Notifications ----------

enum NotificationType {
  upload_completed
  upload_failed
  needs_review
  brief_ready
  hotel_suspended
  password_reset
  feature_toggled
  kpi_warning
}

enum NotificationScope {
  platform
  hotel
}

/**
 * One row per recipient (not a broadcast + read-receipts join table) — a
 * hotel-wide event (e.g. hotel_suspended) fans out into one row per active
 * member at creation time, so each user's read/unread state is a plain
 * column on their own row, not a derived join (Enterprise v2 Phase 12).
 */
model Notification {
  id        String            @id @default(cuid())
  scope     NotificationScope
  hotelId   String?
  hotel     Hotel?            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  titleEn   String
  titleAr   String
  bodyEn    String?
  bodyAr    String?
  sourceRef String?
  readAt    DateTime?
  createdAt DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([hotelId, createdAt])
  @@index([userId, readAt])
}

// ---------- Audit ----------

model AuditLog {
  id        String   @id @default(cuid())
  hotelId   String?
  hotel     Hotel?   @relation(fields: [hotelId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  metadata  Json     @default("{}")
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([hotelId, createdAt])
  @@index([userId, createdAt])
}

// ---------- Settings & Subscriptions ----------

model HotelSetting {
  id      String @id @default(cuid())
  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  key     String
  value   Json

  @@unique([hotelId, key])
}

model Subscription {
  id               String    @id @default(cuid())
  hotelId          String    @unique
  hotel            Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  plan             String    @default("pilot")
  status           String    @default("active")
  currentPeriodEnd DateTime?
}
