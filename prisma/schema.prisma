// HotelOS database schema — implements docs/DATABASE_SCHEMA.md plus the
// Timeline/Memory additions from docs/ARCHITECTURE.md §14-15 (see
// docs/DECISIONS.md "Post-Pivot Consistency Review" for why this file is
// ahead of the Phase-0 DATABASE_SCHEMA.md doc, which predates the pivot).

// Prisma 7: no `url` here — connection URLs live in prisma.config.ts (for
// the CLI/migrations) and are supplied to PrismaClient via a driver adapter
// at runtime (see src/lib/prisma.ts). This is also what makes the client
// Cloudflare Workers-compatible: Prisma 7 has no Rust query-engine binary
// path anymore, only the driver-adapter path (Architecture, Cloudflare
// deployment docs).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------- Identity & Access ----------

enum Language {
  ar
  en
}

enum UserStatus {
  active
  disabled
}

model User {
  id                 String     @id @default(cuid())
  username           String     @unique
  passwordHash       String
  displayName        String
  preferredLanguage  Language   @default(ar)
  isSuperAdmin       Boolean    @default(false)
  status             UserStatus @default(active)
  // Set whenever a temporary password is issued (initial Hotel Admin
  // creation, admin-triggered reset) — enforced at the (app) layout level,
  // blocking access to the rest of the product until the user sets their
  // own password. Never true for a user who chose their own password.
  mustChangePassword Boolean    @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  memberships             HotelMembership[]
  sessions                Session[]
  passwordResets          PasswordResetToken[]
  uploads                 ReportUpload[]
  correctedMetrics        HotelMetric[]             @relation("MetricCorrectedBy")
  aiConversations         AIConversation[]
  exportedReports         ExportedReport[]
  auditLogs               AuditLog[]
  timelineEvents          TimelineEvent[]
  groundTruthRecords      ExtractionGroundTruth[]
  notifications           Notification[]
  generatedAiSummaries    AiExecutiveSummary[]      @relation("AiSummaryGeneratedBy")
  generatedAiIntelligence AiExecutiveIntelligence[] @relation("AiIntelligenceGeneratedBy")
  createdAnalysisSessions AnalysisSession[]
}

model Session {
  // Not a @default(cuid()) — the id itself is the bearer session token
  // (crypto.randomBytes(32), generated in src/server/modules/auth/session.ts),
  // so a leaked cuid-shaped id elsewhere in the app never doubles as a valid
  // session credential.
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

enum HotelStatus {
  active
  suspended
  archived
}

model Hotel {
  id                String      @id @default(cuid())
  name              String
  logoUrl           String?
  country           String
  city              String
  timezone          String
  currency          String      @default("SAR")
  totalRooms        Int
  roomTypes         Json        @default("[]")
  pmsType           String?
  licenseStartDate  DateTime?
  licenseExpiryDate DateTime?
  status            HotelStatus @default(active)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Executive Intelligence Report branding (EDI Phase 1) — all nullable,
  // never backfilled. A report with a missing field shows an honest
  // configurable placeholder (Constitution truth test), never a fabricated
  // name/title. `name` above stays the operational/display name used
  // everywhere else in the app; these are specifically the cover-page
  // identity fields, distinct because a hotel's official bilingual legal
  // name can differ from what's shown in nav/lists.
  officialNameAr      String?
  officialNameEn      String?
  propertyCode        String?
  generalManagerName  String?
  generalManagerTitle String?
  contactPhone        String?
  contactEmail        String?
  address             String?
  reportFooterText    String?

  memberships             HotelMembership[]
  reportUploads           ReportUpload[]
  metrics                 HotelMetric[]
  insights                Insight[]
  alerts                  Alert[]
  recommendations         Recommendation[]
  aiConversations         AIConversation[]
  exportedReports         ExportedReport[]
  auditLogs               AuditLog[]
  settings                HotelSetting[]
  subscription            Subscription?
  timelineEvents          TimelineEvent[]
  notifications           Notification[]
  aiExecutiveSummaries    AiExecutiveSummary[]
  aiExecutiveIntelligence AiExecutiveIntelligence[]
  analysisSessions        AnalysisSession[]

  @@index([status])
}

enum HotelRole {
  HOTEL_ADMIN
  GENERAL_MANAGER
  FRONT_OFFICE_MANAGER
  REVENUE_MANAGER
  ANALYST
  READ_ONLY
}

enum MembershipStatus {
  active
  revoked
}

model HotelMembership {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotelId   String
  hotel     Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  role      HotelRole
  status    MembershipStatus @default(active)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, hotelId])
  @@index([hotelId, userId])
}

// ---------- Reports & Extraction ----------

enum ReportUploadStatus {
  uploaded
  processing
  needs_review
  complete
  error
}

model ReportUpload {
  id               String             @id @default(cuid())
  hotelId          String
  hotel            Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  uploadedByUserId String
  uploadedBy       User               @relation(fields: [uploadedByUserId], references: [id])
  originalFilename String
  storageKey       String
  fileSizeBytes    Int
  checksumSha256   String
  mimeType         String
  status           ReportUploadStatus @default(uploaded)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Nullable (EDI Phase 1) — every upload that predates the Analysis
  // Session model simply has this unset, a valid permanent state, not an
  // error. Historical uploads keep showing in Archive exactly as before;
  // only session-tagged uploads show on the Upload page's session cards.
  analysisSessionId String?
  analysisSession   AnalysisSession? @relation(fields: [analysisSessionId], references: [id], onDelete: SetNull)

  documents ReportDocument[]

  @@index([hotelId, createdAt])
  @@index([hotelId, status])
  @@index([hotelId, uploadedByUserId])
  @@index([analysisSessionId])
}

enum ReportType {
  MANAGER_FLASH
  RESERVATION_STATISTICS
  OPEN_BALANCE
  RESERVATION_STATISTICS_1
  // Added EDI Phase 1 — required Analysis Session slots with no extraction
  // adapter yet (no known field layout to build against). Upload/type-match
  // only for now; see report-extraction/adapters/ for the honest "not yet
  // structurally validated" distinction from MANAGER_FLASH.
  HISTORY_FORECAST
  DAY_MTD_YTD_STATISTICS
  GENERIC
}

// One open Analysis Session per hotel at a time (EDI Phase 1) — the
// coordinating unit for "today's work": which uploads belong together, what
// pipeline stage the background Executive Analysis job is at, and a stable
// id to poll/navigate around. Deliberately thin — HotelMetric/Insight
// already converge naturally per (hotelId, metricDate), so this model does
// not duplicate metric storage, only workflow/progress state.
// `stalled` (Zero-Lag Sprint, Incident #1) — reachable only by the poll-time
// staleness check in analysis-sessions/queries.ts, never set directly by the
// pipeline itself: if the background job dies (Vercel function killed,
// unhandled crash outside the pipeline's own try/catch) with no chance to
// call markAnalysisSessionError, the row would otherwise sit in `analyzing`
// forever with no way to distinguish "still working" from "silently dead" —
// the exact bug this sprint's Incident #1 was opened to fix.
enum AnalysisSessionStatus {
  collecting
  analyzing
  ready
  error
  stalled
}

// Renamed to name the real work at each step precisely (Zero-Lag Sprint) —
// `queued` is new (the instant between "Start Executive Analysis" being
// clicked and the background job's first heartbeat); `stalled` is new (see
// AnalysisSessionStatus.stalled above). Confirmed zero production rows used
// the old intermediate stage names before this rename (only `complete` and
// null existed), so this is a same-day, zero-data-risk rename, not a
// backward-compat concern.
enum AnalysisSessionStage {
  queued
  extracting
  normalizing
  validating
  calculating_metrics
  building_executive_score
  generating_executive_intelligence
  preparing_executive_report
  completed
  failed
  stalled
}

model AnalysisSession {
  id              String                @id @default(cuid())
  hotelId         String
  hotel           Hotel                 @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  businessDate    DateTime
  status          AnalysisSessionStatus @default(collecting)
  currentStage    AnalysisSessionStage?
  createdByUserId String
  createdBy       User                  @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime              @default(now())
  // Zero-Lag Sprint, Incident #1 — the durable processing state machine.
  // `startedAt` is set once, when "Start Executive Analysis" is clicked
  // (distinct from `createdAt`, which is when the session was opened for
  // uploads, often much earlier). `heartbeatAt` is written by the background
  // pipeline before/after every real stage transition; if it stops advancing
  // for more than 60s while status is still `analyzing`, the next poll marks
  // the session `stalled` (see queries.ts's checkAndMarkStalled). `attemptCount`
  // increments on every Start/Resume/Retry click, so a session's real retry
  // history is visible, not just its current state. `errorCode` is a short,
  // stable machine-readable reason (distinct from `errorMessage`'s
  // human-readable text) for future automated handling/alerting.
  startedAt       DateTime?
  heartbeatAt     DateTime?
  attemptCount    Int                   @default(0)
  errorCode       String?
  completedAt     DateTime?
  errorMessage    String?

  uploads ReportUpload[]

  @@index([hotelId, status])
  @@index([hotelId, businessDate])
}

enum DataQualityValidationStatus {
  passed
  flagged
  failed
}

model ReportDocument {
  id                   String       @id @default(cuid())
  reportUploadId       String
  reportUpload         ReportUpload @relation(fields: [reportUploadId], references: [id], onDelete: Cascade)
  hotelId              String
  reportType           ReportType
  detectedReportDate   DateTime?
  confirmedReportDate  DateTime?
  extractionConfidence Float?
  rawExtractedText     String?
  checksumSha256       String
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  // Data Quality Engine (Architecture §33) — populated at the validate stage.
  completenessScore Float?
  validationStatus  DataQualityValidationStatus?
  qualityNotes      Json                         @default("[]")
  // Non-fatal parser-level warnings (Validation Phase §1/§3) — distinct from
  // per-field qualityNotes: these are about the extraction attempt itself
  // (e.g. "no title marker found"), not about a specific metric.
  parserWarnings    Json                         @default("[]")

  // Candidate values pending manual review (PRD §4) — normalization into
  // HotelMetric happens only after user confirmation (Roadmap M4).
  extractedFields Json @default("[]")

  extractionJobs ExtractionJob[]
  metrics        HotelMetric[]
  groundTruth    ExtractionGroundTruth?

  @@index([hotelId, reportType, confirmedReportDate])
}

// Real Data Mode (Validation Phase §9): an engineer-entered set of expected
// field values for one report, used only to measure parser accuracy — never
// read by the normal report workflow. One per ReportDocument. Populating
// this against a real Opera export and running `compareExtractionAccuracy`
// is how "current accuracy" in the Validation Report stops being "unmeasured."
model ExtractionGroundTruth {
  id               String         @id @default(cuid())
  reportDocumentId String         @unique
  reportDocument   ReportDocument @relation(fields: [reportDocumentId], references: [id], onDelete: Cascade)
  expectedFields   Json           @default("{}")
  notes            String?
  recordedByUserId String
  recordedBy       User           @relation(fields: [recordedByUserId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

enum ExtractionStage {
  upload
  extract
  validate
  normalize
  analyze
  complete
  error
}

model ExtractionJob {
  id               String          @id @default(cuid())
  reportDocumentId String
  reportDocument   ReportDocument  @relation(fields: [reportDocumentId], references: [id], onDelete: Cascade)
  stage            ExtractionStage @default(upload)
  attempt          Int             @default(1)
  startedAt        DateTime        @default(now())
  completedAt      DateTime?
  errorMessage     String?

  @@index([reportDocumentId])
}

// ---------- Metrics ----------

model MetricDefinition {
  key        String  @id
  labelEn    String
  labelAr    String
  unit       String
  isComputed Boolean @default(false)

  metrics HotelMetric[]
}

model HotelMetric {
  id                     String           @id @default(cuid())
  hotelId                String
  hotel                  Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  metricDate             DateTime
  metricKey              String
  metricDefinition       MetricDefinition @relation(fields: [metricKey], references: [key])
  value                  Float?
  sourceReportDocumentId String?
  sourceReportDocument   ReportDocument?  @relation(fields: [sourceReportDocumentId], references: [id])
  isManuallyCorrected    Boolean          @default(false)
  correctedByUserId      String?
  correctedBy            User?            @relation("MetricCorrectedBy", fields: [correctedByUserId], references: [id])
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@unique([hotelId, metricDate, metricKey])
  @@index([hotelId, metricDate])
}

// ---------- Insights ----------

model Insight {
  id                 String   @id @default(cuid())
  hotelId            String
  hotel              Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  insightDate        DateTime
  healthScore        Float?
  healthScoreFactors Json     @default("[]")
  generatedAt        DateTime @default(now())

  alerts          Alert[]
  recommendations Recommendation[]

  @@unique([hotelId, insightDate])
  @@index([hotelId, insightDate])
}

enum AlertSeverity {
  critical
  warning
  info
}

enum AlertStatus {
  open
  acknowledged
  resolved
}

model Alert {
  id               String           @id @default(cuid())
  hotelId          String
  hotel            Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  insightId        String?
  insight          Insight?         @relation(fields: [insightId], references: [id])
  severity         AlertSeverity
  category         String
  messageEn        String
  messageAr        String
  relatedMetricKey String?
  status           AlertStatus      @default(open)
  createdAt        DateTime         @default(now())
  // Added Executive Decision Intelligence redesign — nullable, never
  // backfilled. Null for alerts with no real department owner (e.g. the
  // data_quality category is a data-integrity flag, not a hotel function's
  // responsibility) — left null honestly rather than guessed.
  department       HotelDepartment?

  @@index([hotelId, createdAt])
  @@index([insightId])
}

enum RecommendationCategory {
  risk
  opportunity
  action
}

// Hotel department taxonomy (Executive Decision Intelligence redesign) —
// explicitly distinct from HotelRole above: HotelRole is which internal
// HotelOS *user* role should act on something; HotelDepartment is which
// hotel *business function* is accountable for it. The two frequently
// diverge (e.g. an out-of-order-room recommendation's owner stays
// GENERAL_MANAGER — they're accountable for follow-through — while its
// department is MAINTENANCE, the function that actually does the work).
// SALES and CORPORATE_OFFICE exist for completeness but have no rule
// mapped to them yet — never force-fit an existing rule into an unrelated
// department just to use every enum value.
enum HotelDepartment {
  FRONT_OFFICE
  REVENUE_MANAGEMENT
  SALES
  FINANCE
  HOUSEKEEPING
  MAINTENANCE
  GENERAL_MANAGER
  CORPORATE_OFFICE
}

// Deterministic Risk Matrix classification — see
// insights/classification.ts's classifySeverity() for how this is computed
// from a rule's existing priority + real magnitude-past-threshold. Never an
// AI judgment call; risk-category recommendations only.
enum RiskSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

// Deterministic Opportunity Matrix classification — a fixed constant per
// rule family (see insights/rules.ts), not a formula, since only one
// opportunity rule exists today. Opportunity-category recommendations only.
enum OpportunityValue {
  QUICK_WIN
  HIGH_ROI
  LONG_TERM
}

// Decision Timeline bucket — answers "when must someone start acting,"
// distinct from the existing free-text `timeframe` field below, which
// answers "by when should the outcome be achieved." A priority-1 risk
// always gets IMMEDIATE regardless of its timeframe string, since the
// right response to a critical signal starts today even when the target
// outcome has a longer runway.
enum DecisionWindow {
  IMMEDIATE
  HOURS_72
  WEEK
  MONTH
}

model Recommendation {
  id                String                 @id @default(cuid())
  hotelId           String
  hotel             Hotel                  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  insightId         String
  insight           Insight                @relation(fields: [insightId], references: [id])
  priority          Int
  // "Why" (Decision Engine, Architecture §31/§27): the rationale, in the
  // requesting user's language, referencing the supporting metrics below.
  textEn            String
  textAr            String
  // Distinct from the rationale — a concrete, actionable next step.
  suggestedActionEn String
  suggestedActionAr String
  // v0.1 recommendations are deterministic/rule-based (see insights module),
  // so confidence reflects rule certainty, not a model's self-reported
  // confidence — kept as a float for a consistent shape once AI-generated
  // recommendations (Roadmap M6+) populate it differently.
  confidence        Float
  // Traceability (Constitution truth test): which HotelMetric rows this
  // recommendation was computed from, with enough detail to re-derive it.
  supportingMetrics Json                   @default("[]")
  category          RecommendationCategory
  // Outcome tracking seeds the Hotel Genome (Architecture §15 v0.1 scope) —
  // "open" until a user accepts/dismisses/supersedes it.
  status            String                 @default("open")
  createdAt         DateTime               @default(now())
  // Added Analytics fix Phase 6 — all three nullable and never backfilled:
  // rows created before this migration show "not available" honestly rather
  // than a fabricated guess (Constitution truth test). Populated
  // deterministically by insights/rules.ts at rule-evaluation time, same
  // vocabulary HotelRole already uses (owner is who should act on this).
  owner             HotelRole?
  timeframe         String?
  expectedOutcomeEn String?
  expectedOutcomeAr String?
  // Added Executive Decision Intelligence redesign — same discipline as the
  // Phase 6 fields above: all nullable, never backfilled, populated
  // deterministically by insights/rules.ts (department/decisionWindow on
  // every rule) and insights/classification.ts's classifySeverity()
  // (severity on risk-category rules, opportunityValue on opportunity-
  // category rules — a recommendation only ever has one of the two, since
  // `category` already determines which applies).
  department        HotelDepartment?
  severity          RiskSeverity?
  opportunityValue  OpportunityValue?
  decisionWindow    DecisionWindow?

  @@index([hotelId, createdAt])
  @@index([insightId])
}

// Persisted AI Executive Summary (Perf fix, Phase 1B) — before this model,
// generateExecutiveSummary() ran on every single page render of Mission
// Control and Executive Export with no caching, meaning every page view
// made a live AI API call. One row per (hotel, date, language); read
// through getOrRefreshExecutiveSummary() in ai-orchestration/commands.ts,
// which regenerates only on staleness (see isStale()), not on every read.
model AiExecutiveSummary {
  id                     String   @id @default(cuid())
  hotelId                String
  hotel                  Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  metricDate             DateTime
  language               Language
  summaryText            String
  // Snapshot of CitedMetric[] at generation time — avoids recomputing
  // citations on every read; the underlying HotelMetric rows remain the
  // real source of truth (Constitution truth test), this is a display cache.
  citedMetrics           Json     @default("[]")
  model                  String
  promptVersion          Int
  analysisVersion        Int
  sourceReportDocumentId String?
  generatedAt            DateTime @default(now())
  // Null for a system-generated (cache-miss) summary; set only when a user
  // explicitly clicked Regenerate.
  generatedByUserId      String?
  generatedBy            User?    @relation("AiSummaryGeneratedBy", fields: [generatedByUserId], references: [id])

  @@unique([hotelId, metricDate, language])
  @@index([hotelId, metricDate])
}

// Persisted AI Executive Intelligence narrative (Executive Decision
// Intelligence redesign) — a distinct model from AiExecutiveSummary above,
// not an extension of it: AiExecutiveSummary is a single 3-5 sentence
// blob with a unique-per-(hotel,date,language) shape that doesn't fit a
// multi-section document, so this is additive rather than a schema change
// to the existing, already-working summary. Same caching contract as
// AiExecutiveSummary (one row per hotel/date/language, read through
// getOrRefreshExecutiveIntelligence()'s staleness check, not regenerated
// on every read) and the same discipline: every text field here is prose
// *interpreting* real, already-persisted, already-classified data (see
// Recommendation.department/severity/opportunityValue/decisionWindow,
// EDI Phase 1) — nothing numeric is decided by the model itself.
model AiExecutiveIntelligence {
  id                      String   @id @default(cuid())
  hotelId                 String
  hotel                   Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  metricDate              DateTime
  language                Language
  // 5-8 paragraph Executive Morning Brief narrative, in the voice of an
  // experienced GM — the report's opening "read this first" content.
  executiveMessage        String
  // Explains real relationships between independently-stored metric
  // deltas (e.g. occupancy up, ADR down, revenue flat → discount-driven
  // growth) — never a resurrected RevPAR=ADR×Occupancy% identity (see
  // insights/consistency.ts's doc comment on why that was abandoned).
  crossKpiNarrative       String
  // Both Json, keyed by the real Recommendation.id each elaboration/
  // estimate is about — those rows are already persisted (recomputeInsight
  // runs earlier in the same pipeline) before this generation call fires,
  // so every key here is real and checkable, never invented.
  riskElaboration         Json     @default("{}")
  opportunityElaboration  Json     @default("{}")
  businessImpactEstimates Json     @default("{}")
  // Final-page "Executive Decision Summary" prose.
  decisionSummaryText     String
  // Qualified commentary on the real forecast_* metrics — null when there
  // isn't enough forecast data to say anything beyond the raw numbers
  // already shown elsewhere on the report.
  forecastNarrative       String?
  // Executive Decision Intelligence redesign, Phase 5 — three short,
  // audience-tailored recommendations (General Manager: today's operational
  // execution; Owner: financial/ROI stewardship framing; Regional Director:
  // portfolio/escalation framing) built from the exact same real
  // classified data as executiveMessage, just addressed to three different
  // real readers of the same report. Json rather than three columns since
  // it's always read/written as one unit, never queried by sub-key.
  audienceRecommendations Json     @default("{}")
  // The report's final paragraph(s) — current business position, whether
  // management is moving in the right direction, what needs immediate
  // executive attention, what to monitor over the next 7 days. Deliberately
  // excludes a self-reported "confidence in this report" claim (Phase 5's
  // Executive Review requires that be a real computed signal, not the model
  // grading its own output) — see reports/export/page.tsx's deterministic
  // reportConfidence computation instead.
  closingStatement        String
  model                   String
  promptVersion           Int
  analysisVersion         Int
  sourceReportDocumentId  String?
  generatedAt             DateTime @default(now())
  generatedByUserId       String?
  generatedBy             User?    @relation("AiIntelligenceGeneratedBy", fields: [generatedByUserId], references: [id])

  @@unique([hotelId, metricDate, language])
  @@index([hotelId, metricDate])
}

// ---------- Agents & AI ----------

model AIConversation {
  id        String   @id @default(cuid())
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  agentId   String   @default("executive-agent")
  title     String?
  createdAt DateTime @default(now())

  messages AIMessage[]

  @@index([hotelId, userId, createdAt])
}

enum AIMessageRole {
  user
  assistant
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           AIMessageRole
  content        String
  citedSources   Json           @default("[]")
  messageType    Json           @default("{}")
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
}

// ---------- Hotel Timeline (Architecture §14) ----------

enum TimelineEventType {
  report_uploaded
  report_extracted
  report_finalized
  metric_corrected
  alert_raised
  alert_resolved
  recommendation_issued
  ai_conversation
  ai_summary_generated
  export_generated
  decision_logged
}

model TimelineEvent {
  id          String            @id @default(cuid())
  hotelId     String
  hotel       Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  eventType   TimelineEventType
  actorUserId String?
  actor       User?             @relation(fields: [actorUserId], references: [id])
  payload     Json              @default("{}")
  sourceRef   String?
  createdAt   DateTime          @default(now())

  @@index([hotelId, createdAt])
}

// ---------- Exports & Archive ----------

enum ExportStatus {
  generated
  failed
}

model ExportedReport {
  id                String       @id @default(cuid())
  hotelId           String
  hotel             Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  generatedByUserId String
  generatedBy       User         @relation(fields: [generatedByUserId], references: [id])
  language          Language
  periodStart       DateTime
  periodEnd         DateTime
  storageKey        String?
  status            ExportStatus @default(generated)
  createdAt         DateTime     @default(now())

  @@index([hotelId, createdAt])
}

// ---------- Notifications ----------

enum NotificationType {
  upload_completed
  upload_failed
  needs_review
  brief_ready
  hotel_suspended
  password_reset
  feature_toggled
  kpi_warning
}

enum NotificationScope {
  platform
  hotel
}

/**
 * One row per recipient (not a broadcast + read-receipts join table) — a
 * hotel-wide event (e.g. hotel_suspended) fans out into one row per active
 * member at creation time, so each user's read/unread state is a plain
 * column on their own row, not a derived join (Enterprise v2 Phase 12).
 */
model Notification {
  id        String            @id @default(cuid())
  scope     NotificationScope
  hotelId   String?
  hotel     Hotel?            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  titleEn   String
  titleAr   String
  bodyEn    String?
  bodyAr    String?
  sourceRef String?
  readAt    DateTime?
  createdAt DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([hotelId, createdAt])
  @@index([userId, readAt])
}

// ---------- Audit ----------

model AuditLog {
  id        String   @id @default(cuid())
  hotelId   String?
  hotel     Hotel?   @relation(fields: [hotelId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  metadata  Json     @default("{}")
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([hotelId, createdAt])
  @@index([userId, createdAt])
  // Global admin/audit console + platform KPI queries order by createdAt
  // across the whole table with no hotelId/userId filter at all — neither
  // existing index covers that (Zero-Lag Sprint).
  @@index([createdAt])
  // Narrows to one hotel's rows for one action before the per-row JSON-path
  // filter on `metadata` runs (getMetricCorrectionHistoryForKeys) — neither
  // existing index covers `action` (Zero-Lag Sprint).
  @@index([hotelId, action, createdAt])
}

// ---------- Settings & Subscriptions ----------

model HotelSetting {
  id      String @id @default(cuid())
  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  key     String
  value   Json

  @@unique([hotelId, key])
}

model Subscription {
  id               String    @id @default(cuid())
  hotelId          String    @unique
  hotel            Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  plan             String    @default("pilot")
  status           String    @default("active")
  currentPeriodEnd DateTime?
}
